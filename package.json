  "private": true,
  "dependencies": {
    "cra-template": "1.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "prestart": "tailwindcss -c tailwind.config.js -i ./src/tailwind.css -o ./public/tailwind.css",
